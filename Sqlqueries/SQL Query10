


----which brands contribute to the more sales



create view datasegmentation as
with brandsales as
(
select  brand,
        count(units_sold) [total_units_sold] ,
        cast(sum(sales_amount) as int)[total_sales] 
from salesfact f
left join productdim s 
on f.product_key = s.product_key 
group by brand
)
select brand,
total_units_sold,
total_sales,
case

when total_units_sold >3000 then 'In Demand'
when total_units_sold>2000 then 'Medium Demand'
else 'Low Demand'

end [demand_level]
from brandsales



